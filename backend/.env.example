# Polis 后端环境变量模板（复制为 .env；真实 .env 不入库）
# 全部以 POLIS_ 为前缀

POLIS_ENV=dev   # dev|test|local 宽松；其它值视为生产，启动会校验下列安全项（TD-013）

# 生产必填（env 非 dev/test/local 时强制；不满足应用拒绝启动）：
#   JWT 密钥：openssl rand -base64 48 生成，≥32 字符，禁用 dev 默认值
# POLIS_JWT_SECRET=__generate_strong_secret__
#   CORS：收紧到具体前端域，禁用通配 "*"
# POLIS_CORS_ORIGINS=["https://app.example.com"]
#   邮件投递：生产必须配置 SMTP，用于找回密码
# POLIS_PUBLIC_APP_URL=https://app.example.com
# POLIS_MAIL_BACKEND=smtp
# POLIS_MAIL_FROM=noreply@example.com
# POLIS_MAIL_SMTP_HOST=smtp.example.com
# POLIS_MAIL_SMTP_PORT=587
# POLIS_MAIL_SMTP_USERNAME=__smtp_username__
# POLIS_MAIL_SMTP_PASSWORD=__smtp_password__
# POLIS_MAIL_SMTP_STARTTLS=true

# 后续里程碑新增（M1 起）：
# POLIS_DATABASE_URL=postgresql+asyncpg://polis:polis@localhost:5432/polis
# POLIS_TEMPORAL_ADDR=localhost:7233

# 本地开发可把找回密码邮件写入 jsonl outbox；dev/local 仍会在 API 响应回显 reset_token 便于联调。
# POLIS_MAIL_BACKEND=file
# POLIS_MAIL_FROM=noreply@polis.local
# POLIS_MAIL_OUTBOX_PATH=var/mail-outbox.jsonl

# 模型接入（M6）。密钥永不入库；KMS 主密钥生成：openssl rand -base64 32
# POLIS_DEEPSEEK_API_KEY=sk-__your_key__
# POLIS_DEEPSEEK_BASE_URL=https://api.deepseek.com
# POLIS_DEFAULT_CHAT_MODEL=deepseek-v4-pro
# POLIS_EMBEDDING_BASE_URL=http://localhost:8082      # 本地 TEI(bge-large-zh-v1.5, 1024 维)
# POLIS_RERANK_MODEL=                                  # 可选 LiteLLM rerank 模型；留空则本地排序
# POLIS_KMS_MASTER_KEY=__generate_base64_32B__
# 关键节点质量门：首评落在 [0.6, 0.68] 时才独立复核并取低分
# POLIS_QUALITY_GATE_TAU=0.6
# POLIS_QUALITY_GATE_DOUBLE_JUDGE=true
# POLIS_QUALITY_GATE_DOUBLE_JUDGE_MARGIN=0.08

# 对象存储 MinIO（V2-P2a）。access/secret 与 infra/.env 的 MINIO_ROOT_* 一致；生产须 SECURE=true。
# POLIS_MINIO_ENDPOINT=localhost:9000
# POLIS_MINIO_ACCESS_KEY=polis
# POLIS_MINIO_SECRET_KEY=change_me_local_only
# POLIS_MINIO_BUCKET=polis
# POLIS_MINIO_SECURE=false

# Langfuse 可观测（M6-H）。keys 与 infra/.env 的 LANGFUSE_INIT_* 一致
# POLIS_LANGFUSE_ENABLED=true
# POLIS_LANGFUSE_HOST=http://localhost:3001
# POLIS_LANGFUSE_PUBLIC_KEY=pk-lf-polis-localdev
# POLIS_LANGFUSE_SECRET_KEY=sk-lf-__same_as_infra__

# Guardrails provider（TD-026）。默认 rules；启用 Guardrails-AI 时须安装可选包并提供 rail 文件。
# POLIS_GUARDRAILS_PROVIDER=guardrails_ai
# POLIS_GUARDRAILS_PROVIDER_PATH=polis.modules.runtime.guardrails_ai_adapter:build
# POLIS_GUARDRAILS_AI_OUTPUT_RAIL_PATH=/etc/polis/guardrails/output.rail
# POLIS_GUARDRAILS_AI_INPUT_RAIL_PATH=/etc/polis/guardrails/input.rail
# 可选：shadow provider 仅记录对照命中计数，不改变输出
# POLIS_GUARDRAILS_SHADOW_PROVIDER_PATH=polis.modules.runtime.guardrails_ai_adapter:build
