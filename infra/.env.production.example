# Polis compose production/staging env template.
# Copy to a secret-managed env file; never commit real values.

POSTGRES_USER=polis
POSTGRES_PASSWORD=__strong_postgres_password__
POSTGRES_DB=polis

LITELLM_MASTER_KEY=__strong_litellm_master_key__

LANGFUSE_NEXTAUTH_SECRET=__openssl_rand_base64_32__
LANGFUSE_SALT=__strong_langfuse_salt__
LANGFUSE_INIT_PUBLIC_KEY=pk-lf-__project_public_key__
LANGFUSE_INIT_SECRET_KEY=sk-lf-__project_secret_key__
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=__strong_admin_password__

MINIO_ROOT_USER=polis
MINIO_ROOT_PASSWORD=__strong_minio_password__

POLIS_ENV=staging
POLIS_LANGFUSE_ENABLED=true
NEXT_PUBLIC_API_BASE=https://app.example.com
NODE_IMAGE=node:22-alpine
POLIS_PUBLIC_APP_URL=https://app.example.com
POLIS_MAIL_BACKEND=smtp
POLIS_MAIL_FROM=noreply@example.com
POLIS_MAIL_SMTP_HOST=smtp.example.com
POLIS_MAIL_SMTP_PORT=587
POLIS_MAIL_SMTP_USERNAME=__smtp_username__
POLIS_MAIL_SMTP_PASSWORD=__smtp_password__
POLIS_MAIL_SMTP_STARTTLS=true

# Backend production-only safety settings. The compose file derives component
# addresses from service names: postgres, temporal, text-embeddings, minio, langfuse.
POLIS_JWT_SECRET=__openssl_rand_base64_48__
POLIS_KMS_MASTER_KEY=__openssl_rand_base64_32__
POLIS_CORS_ORIGINS=["https://app.example.com"]
POLIS_DEEPSEEK_API_KEY=__provider_api_key__

# Edge gateway in the app compose profile. Use stricter values once real traffic
# baselines are available; keep an external CDN/WAF in front for public internet.
API_PORT_BIND=127.0.0.1:8000:8000
WEB_PORT_BIND=127.0.0.1:3000:3000
GATEWAY_PORT_BIND=8080:8080
GATEWAY_AUTH_RATE_PER_IP=10r/m
GATEWAY_AUTH_BURST=20
