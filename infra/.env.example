# Polis 基础设施 compose 的环境变量模板。复制为 infra/.env（不入库）。
# 占位值仅供本地；真实密钥用 `openssl rand -base64 32` 生成，严禁入库/日志。

# Postgres（主库 + temporal/langfuse/litellm 共用实例）
POSTGRES_USER=polis
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=polis

# LiteLLM 网关主密钥（调用网关用，非厂商 Key）
LITELLM_MASTER_KEY=change_me_litellm_master

# Langfuse（生成：openssl rand -base64 32）
LANGFUSE_NEXTAUTH_SECRET=change_me_at_least_32_chars_long_value
LANGFUSE_SALT=change_me_salt_value
# Langfuse headless 初始化（开箱即用；Polis backend 用同一对 keys 自动接入）
LANGFUSE_INIT_PUBLIC_KEY=pk-lf-polis-localdev
LANGFUSE_INIT_SECRET_KEY=sk-lf-change_me_local_only
LANGFUSE_INIT_USER_EMAIL=admin@polis.local
LANGFUSE_INIT_USER_PASSWORD=change_me_local_only

# MinIO 对象存储（V2-P2a）。root 凭证；backend 用同一对（POLIS_MINIO_ACCESS_KEY/SECRET_KEY）接入。
MINIO_ROOT_USER=polis
MINIO_ROOT_PASSWORD=change_me_local_only

# 模型厂商 Key（系统级可选；用户级 BYO-Key 走运行时注入，不放这里）
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
