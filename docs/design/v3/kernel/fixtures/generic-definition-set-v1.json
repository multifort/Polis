          "execution_policy": "autonomous",
          "inheritance_mode": "nearest",
          "allowed_actor_kinds": ["human", "agent"],
          "separation_of_duties_from": [],
          "required_for_commands": ["record_run_started", "record_run_outcome"],
          "assignment_policy_keys": []
        }
      ],
      "state_machine": {
        "initial_state": "draft",
        "states": [
          {"key": "draft", "terminal": false, "category": "open"},
          {"key": "ready", "terminal": false, "category": "active"},
          {"key": "working", "terminal": false, "category": "active"},
          {"key": "completed", "terminal": true, "category": "success"},
          {"key": "failed", "terminal": true, "category": "failure"},
          {"key": "cancelled", "terminal": true, "category": "cancelled"}
        ],
        "transitions": [
          {
            "key": "submit",
            "command_type": "submit_work",
            "from": ["draft"],
            "to": "ready",
            "required_role_slots": ["owner"],
            "guards": [{"op": "input_exists", "path": "/work/inputs/source_result_id"}],
            "policy_keys": [],
            "effects": [{"type": "request_plan"}]
          },
          {
            "key": "start",
            "command_type": "start_work",
            "from": ["ready"],
            "to": "working",
            "required_role_slots": ["owner", "worker"],
            "guards": [{"op": "role_slot_filled", "role_slot_key": "worker"}],
            "policy_keys": ["high_risk_start"],
            "effects": [{"type": "start_run"}]
          },
          {
            "key": "complete",
            "command_type": "complete_work",
            "from": ["working"],
            "to": "completed",
            "required_role_slots": [],
            "guards": [{"op": "evaluation_outcome_is", "value": "pass"}],
            "policy_keys": [],
            "effects": [
              {
                "type": "emit_event",
                "event_type": "work.remediation_completed",
                "payload_mapping": {"op": "object", "fields": {}}
              }
            ]
          },
          {
            "key": "fail",
            "command_type": "fail_work",
            "from": ["working"],
            "to": "failed",
            "required_role_slots": [],
            "guards": [{"op": "evaluation_outcome_is", "value": "fail"}],
            "policy_keys": [],
            "effects": [
              {
