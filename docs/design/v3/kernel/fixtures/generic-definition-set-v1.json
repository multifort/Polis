          "outcome": "pass",
          "reason_code": "RESULT_ACCEPTED",
          "required_evidence_paths": ["/work/latest_result/artifacts/evidence_artifact_id"]
        },
        {
          "key": "outcome_rework",
          "when": [{"op": "eq", "path": "/work/latest_result/facts/outcome_hint", "value": "rework"}],
          "outcome": "rework",
          "reason_code": "RESULT_REWORK_REQUIRED",
          "required_evidence_paths": []
        },
        {
          "key": "outcome_human_review",
          "when": [{"op": "eq", "path": "/work/latest_result/facts/outcome_hint", "value": "human_review"}],
          "outcome": "human_review",
          "reason_code": "RESULT_REVIEW_REQUIRED",
          "required_evidence_paths": []
        },
        {
          "key": "outcome_fail",
          "when": [{"op": "eq", "path": "/work/latest_result/facts/outcome_hint", "value": "fail"}],
          "outcome": "fail",
          "reason_code": "RESULT_FAILED",
          "required_evidence_paths": []
        }
      ],
      "evaluation_default_outcome": "human_review",
      "human_review_reject_action": "rework",
      "child_dependencies": [],
      "triggers": [
        {
          "key": "complete_after_pass",
          "on_event": "work.evaluation_completed",
          "conditions": [{"op": "event_field_matches", "path": "/event/payload/outcome", "value": "pass"}],
