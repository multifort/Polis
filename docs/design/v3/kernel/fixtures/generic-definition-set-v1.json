            "command_type": "complete_work",
            "payload_mapping": {"op": "object", "fields": {}},
            "child_bundle_dependency_key": null
          },
          "max_fires_per_correlation": 1
        },
        {
          "key": "rework_after_rejection",
          "on_event": "work.evaluation_completed",
          "conditions": [{"op": "event_field_matches", "path": "/event/payload/outcome", "value": "rework"}],
          "emit_command": {
            "command_type": "request_rework",
            "payload_mapping": {"op": "object", "fields": {}},
            "child_bundle_dependency_key": null
          },
          "max_fires_per_correlation": 1
        },
        {
          "key": "review_after_uncertain",
          "on_event": "work.evaluation_completed",
          "conditions": [{"op": "event_field_matches", "path": "/event/payload/outcome", "value": "human_review"}],
          "emit_command": {
            "command_type": "request_human_review",
            "payload_mapping": {"op": "object", "fields": {}},
            "child_bundle_dependency_key": null
          },
          "max_fires_per_correlation": 1
        },
        {
          "key": "fail_after_failure",
          "on_event": "work.evaluation_completed",
          "conditions": [{"op": "event_field_matches", "path": "/event/payload/outcome", "value": "fail"}],
          "emit_command": {
            "command_type": "fail_work",
            "payload_mapping": {"op": "object", "fields": {}},
            "child_bundle_dependency_key": null
          },
          "max_fires_per_correlation": 1
        }
      ]
    },
