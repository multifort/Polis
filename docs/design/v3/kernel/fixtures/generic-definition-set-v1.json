          "required": true,
          "min_assignments": 1,
          "max_assignments": 1,
          "responsibility_kind": "accountable",
          "execution_policy": "delegation_allowed",
          "inheritance_mode": "nearest",
          "allowed_actor_kinds": ["human"],
          "separation_of_duties_from": [],
          "required_for_commands": ["submit_work", "start_work", "cancel_work"],
          "assignment_policy_keys": []
